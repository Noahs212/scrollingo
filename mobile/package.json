{
  "name": "scrollingo-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "format": "prettier \"**/*.{ts,tsx}\" --write",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@gorhom/bottom-sheet|react-native-reanimated|react-native-gesture-handler|react-native-screens|react-native-safe-area-context|react-native-paper|react-native-vector-icons|react-native-pager-view|react-native-worklets|@tanstack/react-query|throttle-debounce|uuid-random|@reduxjs/toolkit|immer|redux|react-redux|reselect)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/__tests__/**",
      "!src/**/*.test.{ts,tsx}",
      "!src/**/styles.ts",
      "!src/**/types.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 15,
        "functions": 20,
        "lines": 25,
        "statements": 25
      }
    }
  },
  "dependencies": {
    "@expo/metro-config": "^55.0.9",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5",
    "@react-navigation/material-bottom-tabs": "^6.2.29",
    "@react-navigation/material-top-tabs": "^6.6.14",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@reduxjs/toolkit": "^2",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-crypto": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-paper": "^5.13.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.0.0",
    "react-redux": "^9",
    "throttle-debounce": "^5.0.0",
    "uuid-random": "^1.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@tanstack/eslint-plugin-query": "^5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@types/throttle-debounce": "^5.0.0",
    "babel-preset-expo": "^55.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.0.3",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.1.3"
  },
  "private": true
}
